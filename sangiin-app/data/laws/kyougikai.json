{
  "name": "両院協議会規程",
  "short": "協規",
  "aliases": [
    "両院協議会規程"
  ],
  "enacted": "1947-07-11",
  "enforced": "1947-07-12",
  "lastAmended": null,
  "chapters": [],
  "articles": {
    "1": {
      "title": "第１条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "甲議院において、両院協議会を求めるときは、その件名及び理由を記し文書を以つてこれを乙議院に通知しなければならない。",
          "gou": []
        }
      ]
    },
    "2": {
      "title": "第２条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会の初会の日時は、両議院の議長が協議してこれを定め、その後の会議の日時は、協議会がこれを定める。",
          "gou": []
        }
      ]
    },
    "3": {
      "title": "第３条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会は、両院協議室においてこれを開く。",
          "gou": []
        }
      ]
    },
    "4": {
      "title": "第４条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会の議長は、協議会の議事を整理し、秩序を保持する。",
          "gou": []
        }
      ]
    },
    "5": {
      "title": "第５条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "両議院の協議委員は、各々副議長一人を選定する。議長に事故があるときは、副議長が、議長の職務を行う。",
          "gou": []
        }
      ]
    },
    "6": {
      "title": "第６条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "議長及び副議長に共に事故があるときは、その院の委員の中から、仮議長を選定して、議長の職務を行わせる。",
          "gou": []
        }
      ]
    },
    "7": {
      "title": "第７条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会の議長が討論に加わろうとするときは、その院の副議長をして議長席に著かせなければならない。",
          "gou": []
        }
      ]
    },
    "8": {
      "title": "第８条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会の議事は、両議院の議決が異つた事項及び当然影響をうける事項の範囲を超えてはならない。",
          "gou": []
        }
      ]
    },
    "9": {
      "title": "第９条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議委員は、協議会において同一の事件について、何回でも発言することができる。",
          "gou": []
        }
      ]
    },
    "10": {
      "title": "第１０条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会において、成案を得たときは、各議院の協議委員議長は、各々文書を以つてこれをその議院に報告しなければならない。",
          "gou": []
        }
      ]
    },
    "11": {
      "title": "第１１条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会は、協議会議録二部を作り、両議院の協議委員議長がこれに署名して、各議院に夫々一部を保存する。",
          "gou": []
        }
      ]
    },
    "12": {
      "title": "第１２条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会議録には、出席者の氏名、議事、表決の数、成案その他重要な事項を記載しなければならない。",
          "gou": []
        }
      ]
    },
    "13": {
      "title": "第１３条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会において、懲罰事犯があるときは、協議会の議長は、これをその委員の属する議院の議長に報告して、処分を求めなければならない。",
          "gou": []
        }
      ]
    },
    "14": {
      "title": "第１４条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "協議会の事務は、各議院の参事がこれを掌理する。",
          "gou": []
        }
      ]
    }
  }
}