{
  "name": "常任委員会合同審査会規程",
  "short": "合規",
  "aliases": [
    "常任委員会合同審査会規程"
  ],
  "enacted": "1947-07-11",
  "enforced": "1947-07-12",
  "lastAmended": "2022-04-08",
  "chapters": [],
  "articles": {
    "1": {
      "title": "第１条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "甲議院の常任委員会において、乙議院の常任委員会と合同審査会を開くことを決議したときは、甲議院の常任委員長は審査又は調査すべき件名及び理由を示して、乙議院の常任委員長に合同審査会を開くことを求めなければならない。",
          "gou": []
        },
        {
          "num": 2,
          "text": "乙議院の常任委員会においてこれに同意したときは、その委員長から甲議院の常任委員長にその旨を通知する。",
          "gou": []
        }
      ]
    },
    "2": {
      "title": "第２条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "他の法律の定めるところにより、合同審査会の議を経なければならないものについては、両議院の議長が協議して、合同審査会の開会を両議院の常任委員長に求めることができる。",
          "gou": []
        }
      ]
    },
    "3": {
      "title": "第３条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会は、両議院の常任委員長の協議に基いて、両議院の常任委員又は各議院の常任委員会で選定された委員が合同してこれを開く。",
          "gou": []
        },
        {
          "num": 2,
          "text": "前項の委員を選定する場合には、各議院の常任委員長又は理事は必ず合同審査会の委員にならなければならない。",
          "gou": []
        }
      ]
    },
    "4": {
      "title": "第４条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会の会長は、各議院の常任委員長又は理事が協議してこれに当る。",
          "gou": []
        }
      ]
    },
    "5": {
      "title": "第５条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会の初会の日時及び場所は、両議院の常任委員長が協議してこれを定め、その後の会議の日時及び場所は合同審査会がこれを定める。",
          "gou": []
        }
      ]
    },
    "6": {
      "title": "第６条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会は、その会長の属する議院の議長を経由して、議案の発議者、国務大臣、内閣官房副長官、副大臣及び大臣政務官並びに政府特別補佐人の出席を求めることができる。",
          "gou": []
        }
      ]
    },
    "7": {
      "title": "第７条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会の委員は、議題について自由に質疑し、及び意見を述べることができる。",
          "gou": []
        }
      ]
    },
    "8": {
      "title": "第８条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会は、その審査又は調査する事件については、法律に特別の定のある場合を除いては、表決をすることができない。",
          "gou": []
        },
        {
          "num": 2,
          "text": "合同審査会が、その審査又は調査する事件について、表決をする場合は、各議院の常任委員の各々半数以上が出席していなければならない。",
          "gou": []
        }
      ]
    },
    "9": {
      "title": "第９条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会は、その会長の属する議院の議長を経由して、審査又は調査のため証人の出頭を求めることができる。",
          "gou": []
        }
      ]
    },
    "10": {
      "title": "第１０条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "証人の発言は、その証言を求められた範囲を超えてはならない。",
          "gou": []
        },
        {
          "num": 2,
          "text": "証人の発言が前項の範囲を超え又は証人に不穏当な言動があつたときは、会長はその発言を禁止し又は退場を命ずることができる。",
          "gou": []
        }
      ]
    },
    "11": {
      "title": "第１１条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会は、その会長の属する議院の議長を経由して、審査又は調査のため、内閣官公署その他に対し、必要な報告又は記録の提出を求めることができる。",
          "gou": []
        }
      ]
    },
    "12": {
      "title": "第１２条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会は、議案の審査のために公聴会を開くことができる。",
          "gou": []
        }
      ]
    },
    "13": {
      "title": "第１３条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会において、公聴会を開こうとするときは、予め両議院の議長の承認を得た後、その決議をしなければならない。",
          "gou": []
        }
      ]
    },
    "14": {
      "title": "第１４条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会において、公聴会を開くに決したときは、会長からその旨を両議院の議長に報告すると共に、その日時及び公聴会において意見を聴こうとする案件を公示する。",
          "gou": []
        }
      ]
    },
    "15": {
      "title": "第１５条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会に付された重要な案件について、公聴会を開くことを希望する者、又は合同審査会の公聴会に出席して、意見を述べようとする者は、予め文書を以てその理由及び案件に対する賛否を合同審査会に申し出なければならない。",
          "gou": []
        }
      ]
    },
    "16": {
      "title": "第１６条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "公聴会において、その意見を聴こうとする利害関係者及び学識経験者等（これを公述人という。）は、予め申し出た者及びその他の者の中から合同審査会がこれを定めてその旨を本人に通知する。",
          "gou": []
        },
        {
          "num": 2,
          "text": "予め申し出た者の中に賛成者及び反対者があるときは、その両方から公述人を選ばなければならない。",
          "gou": []
        }
      ]
    },
    "17": {
      "title": "第１７条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "公述人が発言しようとするときは、会長の許可を受けなければならない。",
          "gou": []
        }
      ]
    },
    "18": {
      "title": "第１８条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "公述人の発言は、その意見を聴こうとする事件の範囲を超えてはならない。",
          "gou": []
        },
        {
          "num": 2,
          "text": "公述人の発言がその範囲を超え、又は公述人に不穏当な言動があつたときは、会長はその発言を禁止し又は退場を命ずることができる。",
          "gou": []
        }
      ]
    },
    "19": {
      "title": "第１９条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "公述人は、合同審査会の同意を得た場合には代理人をして意見を述べさせ又は文書で意見を提示することができる。",
          "gou": []
        }
      ]
    },
    "20": {
      "title": "第２０条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会を終つたときは、各議院の常任委員長又は理事から審査の経過及び結果を委員会に報告しなければならない。但し委員会は、文書の報告を求めることができる。",
          "gou": []
        }
      ]
    },
    "21": {
      "title": "第２１条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会は、会議録二部を作り、両議院の常任委員長（又はその代理者）がこれに署名して、各議院に夫々一部を保存する。",
          "gou": []
        }
      ]
    },
    "22": {
      "title": "第２２条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会の会議録には、出席者の氏名、表決の数、公聴会、証人、委員の派遣、報告又は記録の提出の要求、その他重要な事項を記載しなければならない。",
          "gou": []
        }
      ]
    },
    "23": {
      "title": "第２３条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会の会議録は、電磁的記録の提供その他の適当な方法により両議院の議員に提供する。ただし、秘密会議の記録中特に秘密を要するものと合同審査会で決議した部分については、この限りでない。",
          "gou": []
        }
      ]
    },
    "24": {
      "title": "第２４条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会において懲罰事犯があるときは、会長は、これをその委員の属する議院の議長に報告して処分を求めなければならない。",
          "gou": []
        }
      ]
    },
    "25": {
      "title": "第２５条",
      "subject": null,
      "kou": [
        {
          "num": 1,
          "text": "合同審査会の事務は、各議院の参事がこれを掌理する。",
          "gou": []
        }
      ]
    }
  }
}